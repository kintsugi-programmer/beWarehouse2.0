   "source": [
    "# ============================================================\n",
    "# ASSIGNMENT 3 — QUESTION 4\n",
    "# Bartoli's Model of Protein Structure\n",
    "# Proteins: 1ubq, 1hrc, 1csp, 1fkb, 2abd\n",
    "# ============================================================\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import urllib.request\n",
    "import os\n",
    "import random\n",
    "import math\n",
    "from collections import defaultdict\n",
    "\n",
    "# seed for reproducible randomness\n",
    "random.seed(42)\n",
    "np.random.seed(42)\n",
    "\n",
    "protein_ids = ['1ubq', '1hrc', '1csp', '1fkb', '2abd']\n",
    "pdb_dir = 'pdb_files'\n",
    "os.makedirs(pdb_dir, exist_ok=True)\n",
    "print(\"Setup done.\")\n",
    "\n",
    "# ============================================================\n",
    "# DOWNLOAD PDB & EXTRACT CA COORDINATES\n",
    "# ============================================================\n",
    "def grab_pdb(pdb_id):\n",
    "    \"\"\"download a pdb file if we don't have it yet\"\"\"\n",
    "    path = os.path.join(pdb_dir, f\"{pdb_id}.pdb\")\n",
    "    if not os.path.exists(path):\n",
    "        url = f\"https://files.rcsb.org/download/{pdb_id.upper()}.pdb\"\n",
    "        urllib.request.urlretrieve(url, path)\n",
    "        print(f\"  Downloaded {pdb_id}\")\n",
    "    return path\n",
    "\n",
    "def extract_ca_coords(pdb_id):\n",
    "    \"\"\"Extract Cα atom coordinates for chain A, one per residue.\"\"\"\n",
    "    path = grab_pdb(pdb_id)\n",
    "    coords = {}\n",
    "    with open(path, 'r') as f:\n",
    "        for line in f:\n",
    "            if not line.startswith(\"ATOM\"):\n",
    "                continue\n",
    "            atom_name = line[12:16].strip()\n",
    "            chain     = line[21].strip()\n",
    "            if atom_name != 'CA':\n",
    "                continue\n",
    "            if chain not in ('A', ''):\n",
    "                continue\n",
    "            try:\n",
    "                res_seq = int(line[22:26].strip())\n",
    "                x = float(line[30:38])\n",
    "                y = float(line[38:46])\n",
    "                z = float(line[46:54])\n",
    "                if res_seq not in coords:\n",
    "                    coords[res_seq] = (x, y, z)\n",
    "            except ValueError:\n",
    "                continue\n",
    "    # return sorted list of (x,y,z)\n",
    "    sorted_coords = [coords[k] for k in sorted(coords.keys())]\n",
    "    return sorted_coords\n",
    "\n",
    "print(\"Extracting Cα coordinates...\")\n",
    "ca_coords = {}\n",
    "for pid in protein_ids:\n",
    "    ca_coords[pid] = extract_ca_coords(pid)\n",
    "    print(f\"  {pid}: {len(ca_coords[pid])} residues\")\n",
    "\n",
    "# ============================================================\n",
    "# BUILD RIG FROM Q3 (needed for edge count target)\n",
    "# ============================================================\n",
    "def euclidean_dist(a, b):\n",
    "    \"\"\"straight-line distance between two points\"\"\"\n",
    "    return math.sqrt((a[0]-b[0])**2 + (a[1]-b[1])**2 + (a[2]-b[2])**2)\n",
    "\n",
    "def build_rig(coords, cutoff=8.0):\n",
    "    \"\"\"RIG: connect residues whose Cα atoms are within cutoff Angstroms.\"\"\"\n",
    "    n = len(coords)\n",
    "    adj = [[False]*n for _ in range(n)]\n",
    "    edges = []\n",
    "    for i in range(n):\n",
    "        for j in range(i+1, n):\n",
    "            if euclidean_dist(coords[i], coords[j]) <= cutoff:\n",
    "                adj[i][j] = True\n",
    "                adj[j][i] = True\n",
    "                edges.append((i, j))\n",
    "    return adj, edges\n",
    "\n",
    "print(\"\\nBuilding RIG for all proteins (cutoff=8Å)...\")\n",
    "rig_data = {}\n",
    "for pid in protein_ids:\n",
    "    coords = ca_coords[pid]\n",
    "    adj, edges = build_rig(coords)\n",
    "    rig_data[pid] = {'adj': adj, 'edges': edges,\n",
    "                     'n': len(coords), 'coords': coords}\n",
    "    print(f\"  {pid}: {len(coords)} nodes, {len(edges)} edges\")\n",
    "\n",
    "# ============================================================\n",
    "# GRAPH METRICS (L and C)\n",
    "# ============================================================\n",
    "def calc_clustering(adj, n):\n",
    "    \"\"\"Global clustering coefficient.\"\"\"\n",
    "    total_triangles = 0\n",
    "    total_triples   = 0\n",
    "    for i in range(n):\n",
    "        neighbours = [j for j in range(n) if adj[i][j]]\n",
    "        k = len(neighbours)\n",
    "        if k < 2:\n",
    "            continue\n",
    "        total_triples += k * (k - 1)\n",
    "        for a in range(len(neighbours)):\n",
    "            for b in range(a+1, len(neighbours)):\n",
    "                if adj[neighbours[a]][neighbours[b]]:\n",
    "                    total_triangles += 2\n",
    "    return total_triangles / total_triples if total_triples > 0 else 0.0\n",
    "\n",
    "def bfs_distances(adj, n, source):\n",
    "    \"\"\"BFS from source, returns list of distances to all reachable nodes.\"\"\"\n",
    "    dist = [-1] * n\n",
    "    dist[source] = 0\n",
    "    queue = [source]\n",
    "    head = 0\n",
    "    while head < len(queue):\n",
    "        u = queue[head]; head += 1\n",
    "        for v in range(n):\n",
    "            if adj[u][v] and dist[v] == -1:\n",
    "                dist[v] = dist[u] + 1\n",
    "                queue.append(v)\n",
    "    return [d for d in dist if d > 0]\n",
    "\n",
    "def calc_path_length(adj, n):\n",
    "    \"\"\"Average shortest path length over all reachable pairs.\"\"\"\n",
    "    total = 0\n",
    "    count = 0\n",
    "    for i in range(n):\n",
    "        dists = bfs_distances(adj, n, i)\n",
    "        total += sum(dists)\n",
    "        count += len(dists)\n",
    "    return total / count if count > 0 else 0.0\n",
    "\n",
    "print(\"\\nComputing L and C for RIG models...\")\n",
    "rig_metrics = {}\n",
    "for pid in protein_ids:\n",
    "    d  = rig_data[pid]\n",
    "    adj, n = d['adj'], d['n']\n",
    "    L = calc_path_length(adj, n)\n",
    "    C = calc_clustering(adj, n)\n",
    "    rig_metrics[pid] = {'L': L, 'C': C, 'edges': len(d['edges']), 'n': n}\n",
    "    print(f\"  {pid}: L={L:.4f}, C={C:.4f}, edges={len(d['edges'])}\")\n",
    "\n",
    "# ============================================================\n",
    "# BARTOLI'S MODEL\n",
    "# ============================================================\n",
    "def bartoli_model(n, target_edges, seed=None):\n",
    "    \"\"\"\n",
    "    Generate one instance of Bartoli's contact map model.\n",
    "\n",
    "    Steps:\n",
    "    (i)  Set first two diagonals (backbone contacts).\n",
    "    (ii) Randomly pick residue pair (i,j) with prob ∝ 1/|i-j|.\n",
    "    (iii) Set 3x3 block around (i,j) in adjacency matrix.\n",
    "    (iv) Repeat until edge count ≈ target_edges.\n",
    "\n",
    "    Returns adjacency matrix (list of lists).\n",
    "    \"\"\"\n",
    "    if seed is not None:\n",
    "        random.seed(seed)\n",
    "\n",
    "    adj = [[False]*n for _ in range(n)]\n",
    "\n",
    "    # Step (i): backbone — first two diagonals\n",
    "    for i in range(n):\n",
    "        for delta in [1, 2]:\n",
    "            j = i + delta\n",
    "            if j < n:\n",
    "                adj[i][j] = True\n",
    "                adj[j][i] = True\n",
    "\n",
    "    def count_edges(adj, n):\n",
    "        return sum(adj[i][j] for i in range(n) for j in range(i+1, n))\n",
    "\n",
    "    # pre-compute weights: prob ∝ 1/|i-j| for |i-j| > 2\n",
    "    pairs  = [(i, j) for i in range(n) for j in range(i+3, n)]\n",
    "    weights = [1.0 / (j - i) for i, j in pairs]\n",
    "    total_w = sum(weights)\n",
    "    probs   = [w / total_w for w in weights]\n",
    "\n",
    "    # cumulative for fast sampling\n",
    "    cum = []\n",
    "    s = 0.0\n",
    "    for p in probs:\n",
    "        s += p\n",
    "        cum.append(s)\n",
    "\n",
    "    def weighted_sample():\n",
    "        r = random.random()\n",
    "        lo, hi = 0, len(cum)-1\n",
    "        while lo < hi:\n",
    "            mid = (lo+hi)//2\n",
    "            if cum[mid] < r:\n",
    "                lo = mid+1\n",
    "            else:\n",
    "                hi = mid\n",
    "        return pairs[lo]\n",
    "\n",
    "    # Steps (ii)-(iv): add contacts until target reached\n",
    "    max_iter = target_edges * 200\n",
    "    itr = 0\n",
    "    while count_edges(adj, n) < target_edges and itr < max_iter:\n",
    "        itr += 1\n",
    "        i, j = weighted_sample()\n",
    "\n",
    "        # Step (iii): 3x3 Cartesian product block\n",
    "        for di in [-1, 0, 1]:\n",
    "            for dj in [-1, 0, 1]:\n",
    "                ni_, nj_ = i + di, j + dj\n",
    "                if 0 <= ni_ < n and 0 <= nj_ < n and ni_ != nj_:\n",
    "                    adj[ni_][nj_] = True\n",
    "                    adj[nj_][ni_] = True\n",
    "\n",
    "    return adj\n",
    "\n",
    "print(\"\\nBartoli model function defined.\")\n",
    "\n",
    "# ============================================================\n",
    "# RUN A BUNCH OF INSTANCES PER PROTEIN\n",
    "# ============================================================\n",
    "num_instances = 100\n",
    "\n",
    "print(f\"Running {num_instances} Bartoli instances per protein...\")\n",
    "print(\"(This may take ~5-10 minutes)\\n\")\n",
    "\n",
    "bartoli_results = {}\n",
    "\n",
    "for pid in protein_ids:\n",
    "    n            = rig_metrics[pid]['n']\n",
    "    target_edges = rig_metrics[pid]['edges']\n",
    "\n",
    "    L_list = []\n",
    "    C_list = []\n",
    "\n",
    "    for inst in range(num_instances):\n",
    "        adj_b = bartoli_model(n, target_edges, seed=inst)\n",
    "        L_b   = calc_path_length(adj_b, n)\n",
    "        C_b   = calc_clustering(adj_b, n)\n",
    "        L_list.append(L_b)\n",
    "        C_list.append(C_b)\n",
    "\n",
    "    bartoli_results[pid] = {\n",
    "        'L_mean': np.mean(L_list), 'L_std': np.std(L_list),\n",
    "        'C_mean': np.mean(C_list), 'C_std': np.std(C_list)\n",
    "    }\n",
    "    print(f\"  {pid}: L={np.mean(L_list):.4f}±{np.std(L_list):.4f} | \"\n",
    "          f\"C={np.mean(C_list):.4f}±{np.std(C_list):.4f}\")\n",
    "\n",
    "print(\"\\nAll done.\")\n",
    "\n",
    "# ============================================================\n",
    "# COMPARISON TABLE\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\"*75)\n",
    "print(f\"{'Protein':<8} | {'RIG L':>7} | {'RIG C':>7} | \"\n",
    "      f\"{'Bartoli L (mean±std)':>22} | {'Bartoli C (mean±std)':>22}\")\n",
    "print(\"=\"*75)\n",
    "for pid in protein_ids:\n",
    "    rm = rig_metrics[pid]\n",
    "    bm = bartoli_results[pid]\n",
    "    print(f\"{pid:<8} | {rm['L']:>7.4f} | {rm['C']:>7.4f} | \"\n",
    "          f\"{bm['L_mean']:>8.4f} ± {bm['L_std']:.4f}       | \"\n",
    "          f\"{bm['C_mean']:>8.4f} ± {bm['C_std']:.4f}\")\n",
    "print(\"=\"*75)\n",
    "\n",
    "# ============================================================\n",
    "# PART (a) — MODIFIED STEP (ii)\n",
    "# Modification: use Gaussian probability instead of linear 1/|i-j|\n",
    "# This concentrates contacts around sequence-local regions,\n",
    "# better mimicking real folding contact patterns.\n",
    "# ============================================================\n",
    "def bartoli_model_modified(n, target_edges, sigma=15.0, seed=None):\n",
    "    \"\"\"\n",
    "    Modified Bartoli model: prob ∝ exp(-|i-j|² / 2σ²)\n",
    "    instead of 1/|i-j|. Gaussian decay with sigma=15.\n",
    "    This better captures medium-range contacts seen in real proteins.\n",
    "    \"\"\"\n",
    "    if seed is not None:\n",
    "        random.seed(seed)\n",
    "\n",
    "    adj = [[False]*n for _ in range(n)]\n",
    "\n",
    "    # Step (i): backbone\n",
    "    for i in range(n):\n",
    "        for delta in [1, 2]:\n",
    "            j = i + delta\n",
    "            if j < n:\n",
    "                adj[i][j] = True\n",
    "                adj[j][i] = True\n",
    "\n",
    "    def count_edges(adj, n):\n",
    "        return sum(adj[i][j] for i in range(n) for j in range(i+1, n))\n",
    "\n",
    "    # Gaussian weights\n",
    "    pairs   = [(i, j) for i in range(n) for j in range(i+3, n)]\n",
    "    weights = [math.exp(-((j-i)**2) / (2 * sigma**2)) for i,j in pairs]\n",
    "    total_w = sum(weights)\n",
    "    probs   = [w/total_w for w in weights]\n",
    "\n",
    "    cum = []\n",
    "    s = 0.0\n",
    "    for p in probs:\n",
    "        s += p\n",
    "        cum.append(s)\n",
    "\n",
    "    def weighted_sample():\n",
    "        r = random.random()\n",
    "        lo, hi = 0, len(cum)-1\n",
    "        while lo < hi:\n",
    "            mid = (lo+hi)//2\n",
    "            if cum[mid] < r:\n",
    "                lo = mid+1\n",
    "            else:\n",
    "                hi = mid\n",
    "        return pairs[lo]\n",
    "\n",
    "    max_iter = target_edges * 200\n",
    "    itr = 0\n",
    "    while count_edges(adj, n) < target_edges and itr < max_iter:\n",
    "        itr += 1\n",
    "        i, j = weighted_sample()\n",
    "        for di in [-1, 0, 1]:\n",
    "            for dj in [-1, 0, 1]:\n",
    "                ni_, nj_ = i+di, j+dj\n",
    "                if 0 <= ni_ < n and 0 <= nj_ < n and ni_ != nj_:\n",
    "                    adj[ni_][nj_] = True\n",
    "                    adj[nj_][ni_] = True\n",
    "\n",
    "    return adj\n",
    "\n",
    "print(\"Running Modified Bartoli (Gaussian decay)...\")\n",
    "mod_results = {}\n",
    "for pid in protein_ids:\n",
    "    n            = rig_metrics[pid]['n']\n",
    "    target_edges = rig_metrics[pid]['edges']\n",
    "    L_list, C_list = [], []\n",
    "    for inst in range(num_instances):\n",
    "        adj_m = bartoli_model_modified(n, target_edges, sigma=15.0, seed=inst)\n",
    "        L_list.append(calc_path_length(adj_m, n))\n",
    "        C_list.append(calc_clustering(adj_m, n))\n",
    "    mod_results[pid] = {\n",
    "        'L_mean': np.mean(L_list), 'L_std': np.std(L_list),\n",
    "        'C_mean': np.mean(C_list), 'C_std': np.std(C_list)\n",
    "    }\n",
    "    print(f\"  {pid}: L={np.mean(L_list):.4f}±{np.std(L_list):.4f} | \"\n",
    "          f\"C={np.mean(C_list):.4f}±{np.std(C_list):.4f}\")\n",
    "\n",
    "# ============================================================\n",
    "# PART (a) — FULL COMPARISON TABLE\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\"*95)\n",
    "print(f\"{'Protein':<8} | {'RIG L':>6} | {'RIG C':>6} | \"\n",
    "      f\"{'Bartoli L':>10} | {'Bartoli C':>10} | \"\n",
    "      f\"{'Modified L':>12} | {'Modified C':>12}\")\n",
    "print(\"=\"*95)\n",
    "for pid in protein_ids:\n",
    "    rm = rig_metrics[pid]\n",
    "    bm = bartoli_results[pid]\n",
    "    mm = mod_results[pid]\n",
    "    print(f\"{pid:<8} | {rm['L']:>6.3f} | {rm['C']:>6.3f} | \"\n",
    "          f\"{bm['L_mean']:>6.3f}±{bm['L_std']:.3f} | \"\n",
    "          f\"{bm['C_mean']:>6.3f}±{bm['C_std']:.3f} | \"\n",
    "          f\"{mm['L_mean']:>7.3f}±{mm['L_std']:.3f}  | \"\n",
    "          f\"{mm['C_mean']:>7.3f}±{mm['C_std']:.3f}\")\n",
    "print(\"=\"*95)\n",
    "\n",
    "# ============================================================\n",
    "# PART (b) — CONTACTS VS CARTESIAN DISTANCE PLOT\n",
    "# ============================================================\n",
    "def get_contact_distance_data(coords, edges):\n",
    "    \"\"\"\n",
    "    For each contact (edge) in RIG, compute:\n",
    "    - sequence separation |i - j|  (x-axis: 'number of amino acids between them')\n",
    "    - Cartesian distance between Cα atoms\n",
    "    \"\"\"\n",
    "    seq_seps = []\n",
    "    cart_dists = []\n",
    "    for i, j in edges:\n",
    "        seq_seps.append(abs(i - j))\n",
    "        cart_dists.append(euclidean_dist(coords[i], coords[j]))\n",
    "    return seq_seps, cart_dists\n",
    "\n",
    "fig, axes = plt.subplots(2, 3, figsize=(15, 9))\n",
    "axes = axes.flatten()\n",
    "\n",
    "colors = ['steelblue', 'tomato', 'seagreen', 'darkorange', 'purple']\n",
    "\n",
    "for idx, pid in enumerate(protein_ids):\n",
    "    coords = rig_data[pid]['coords']\n",
    "    edges  = rig_data[pid]['edges']\n",
    "\n",
    "    seq_seps, cart_dists = get_contact_distance_data(coords, edges)\n",
    "\n",
    "    ax = axes[idx]\n",
    "    ax.scatter(seq_seps, cart_dists, s=12, alpha=0.5,\n",
    "               color=colors[idx], edgecolors='none')\n",
    "\n",
    "    # trend line\n",
    "    if len(seq_seps) > 2:\n",
    "        z = np.polyfit(seq_seps, cart_dists, 1)\n",
    "        p = np.poly1d(z)\n",
    "        x_line = np.linspace(min(seq_seps), max(seq_seps), 100)\n",
    "        ax.plot(x_line, p(x_line), 'k--', linewidth=1.5, label='Trend')\n",
    "\n",
    "    ax.axhline(y=8.0, color='red', linestyle=':', linewidth=1.2, label='RIG cutoff (8Å)')\n",
    "    ax.set_xlabel('Sequence Separation |i − j| (# amino acids)', fontsize=10)\n",
    "    ax.set_ylabel('Cartesian Distance (Å)', fontsize=10)\n",
    "    ax.set_title(f'Protein {pid.upper()}\\n(n={rig_data[pid][\"n\"]}, edges={len(edges)})',\n",
    "                 fontsize=11, fontweight='bold')\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(True, linestyle='--', alpha=0.4)\n",
    "\n",
    "# hide unused subplot\n",
    "axes[-1].set_visible(False)\n",
    "\n",
    "fig.suptitle('Amino Acid Contacts vs Cartesian Distance\\n(RIG model, cutoff = 8Å)',\n",
    "             fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('Q4b_contacts_vs_distance.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Plot saved as Q4b_contacts_vs_distance.png\")\n",
    "\n",
    "# ============================================================\n",
    "# OBSERVATIONS\n",
    "# ============================================================\n",
    "print(\"\"\"\n",
    "=============================================================\n",
    "OBSERVATIONS — Q4\n",
    "=============================================================\n",
    "\n",
    "PART (a): RIG vs Bartoli vs Modified Bartoli\n",
    "---------------------------------------------\n",
    "1. RIG (real) has HIGHER clustering coefficient (C) than both\n",
    "   Bartoli models → real proteins have tightly packed local\n",
    "   contact communities that random models fail to reproduce.\n",
    "\n",
    "2. Bartoli's L is generally LOWER than real RIG → random\n",
    "   model creates shortcuts not present in real structures,\n",
    "   leading to smaller average path lengths.\n",
    "\n",
    "3. Modified Bartoli (Gaussian decay, σ=15) produces C and L\n",
    "   values CLOSER to real RIG than original Bartoli → medium-\n",
    "   range contacts (not just local or uniform random) are key\n",
    "   to realistic protein topology.\n",
    "\n",
    "4. Both models underestimate C because they do not encode\n",
    "   secondary structure (helices/sheets) which drive real\n",
    "   clustering in protein networks.\n",
    "\n",
    "PART (b): Contacts vs Cartesian Distance\n",
    "------------------------------------------\n",
    "1. Most contacts cluster at SHORT sequence separations\n",
    "   (|i-j| < 10) and short distances (< 8Å) → local backbone\n",
    "   interactions dominate.\n",
    "\n",
    "2. Long-range contacts (|i-j| > 15) also exist at < 8Å →\n",
    "   these arise from tertiary folding bringing distant residues\n",
    "   close in 3D space.\n",
    "\n",
    "3. A better model could use a BIMODAL probability:\n",
    "   - High weight for short-range (|i-j| < 5): local structure\n",
    "   - Moderate weight for specific long-range contacts: tertiary\n",
    "   This would reproduce the observed bimodal contact pattern.\n",
    "=============================================================\n",
    \"\"\")\n"
   ]
  }
